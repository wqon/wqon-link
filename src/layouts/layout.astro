---
import Head from "../components/head.astro";
import Loader from "../components/loader.astro";
import Drake from "../components/drake.astro";
import Header from "../components/header.astro";
---

<html lang="en">
    <!-- Designed and developed with <3 by Lukáš "WQON" Nox. --><!-- For technical details see: https://github.com/wqon/wqon-link -->
    <Head
        pageTitle="WQON - Pixel, Type & Dev"
        pageDesc="A gateway to my world of pixel art, type design and open-source tools."
        ogTitle="Discover the pixel‑crafted universe of WQON"
        ogDesc="Explore my pixel art, type design, and open‑source tools in one unified gateway."
    />
    <body>
        <Loader />
        <div class="cursor"></div>
        <main>
            <section class="wrapper">
                <div class="left">
                    <Drake />
                </div>
                <div class="right">
                    <Header />
                    <nav>
                        <slot />
                    </nav>
                </div>
            </section>
        </main>
    </body>
</html>
