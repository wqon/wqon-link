---
import Scripts from "../scripts.astro";

const { pageTitle, pageDesc, ogTitle, ogDesc } = Astro.props;
const pageCanon = "https://wqon.link/";
---

<head>
    <meta charset="utf-8" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="author" content='Lukáš "WQON" Nox' />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#63abff" />
    <link rel="canonical" href={pageCanon} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDesc} />
    <meta property="og:image" content="https://wqon.link/assets/og.png" />
    <meta property="og:url" content={pageCanon} />

    <link
        rel="icon"
        type="image/png"
        href="/favicon-96x96.png?v=20260425"
        sizes="96x96"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260425" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260425" />
    <link
        rel="apple-touch-icon"
        sizes="180x180"
        href="/apple-touch-icon.png?v=20260425"
    />
    <meta name="apple-mobile-web-app-title" content="WQON" />
    <link rel="manifest" href="/site.webmanifest?v=20260425" />

    <link rel="stylesheet" href="/src/styles.css" />
    <Scripts />
</head>
