---
import "../styles/styles.css";

const { pageTitle, pageDesc, ogTitle, ogDesc } = Astro.props;
---

<head>
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="charset" content="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href="https://wqon.link/" />

    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDesc} />

    <link
        rel="icon"
        type="image/png"
        href="/favicon-96x96.png?v=20260425"
        sizes="96x96"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260425" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260425" />
    <link
        rel="apple-touch-icon"
        sizes="180x180"
        href="/apple-touch-icon.png?v=20260425"
    />
    <meta name="apple-mobile-web-app-title" content="WQON" />
    <link rel="manifest" href="/site.webmanifest?v=20260425" />

    <script src="/src/scripts/cursor.js"></script>
    <script src="/src/scripts/noDrag.js"></script>
    <script src="/src/scripts/killHash.js"></script>
    <script src="/src/scripts/loader.js"></script>
    <script
        data-goatcounter="https://wqonlink.goatcounter.com/count"
        async
        src="//gc.zgo.at/count.js"></script>
</head>
