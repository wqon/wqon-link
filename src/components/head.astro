---
const { pageTitle, pageDesc, ogTitle, ogDesc } = Astro.props;
---

<head>
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="charset" content="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href="https://wqon.link/" />

    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDesc} />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="WQON" />
    <link rel="manifest" href="/site.webmanifest" />

    <script src="/src/scripts/analytics.js"></script>
    <script src="/src/scripts/noDrag.js" is:inline></script>
</head>
